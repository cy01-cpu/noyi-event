generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id            String         @id @default(cuid())
  title         String
  description   String?
  location      String?
  startAt       DateTime
  endAt         DateTime?
  capacity      Int?
  isPublic      Boolean        @default(true)
  requirePayment Boolean       @default(false)
  amount        Int?
  status        EventStatus    @default(DRAFT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  registrations Registration[]
}

// TODO: 疑似重複提醒邏輯（後台顯示用，不阻擋報名送出）
// 查詢同一活動內 email+姓名相同的報名：
// - 若 branch 不同（或其中一筆有填一筆沒填）→ 不標記，大概率是不同真人
// - 若 branch 相同（或兩筆都沒填）→ 標記「⚠️ 疑似重複」，交由承辦人自行判斷
model Registration {
  id        String             @id @default(cuid())
  eventId   String
  event     Event              @relation(fields: [eventId], references: [id])
  name      String
  email     String
  phone     String?
  branch    String?
  note      String?
  token     String             @unique @default(cuid())
  isPaid    Boolean            @default(false)
  paidAt    DateTime?
  // 繳費稽核軌跡：標記已繳費時由操作者自填站別/姓名（仿 CheckIn.gate 的
  // 自填模式，不另建 PaymentLog 表）。取消標記時一併清空。
  paidBy    String?
  // 退費追蹤：已繳費的報名被取消後，錢是否已還回去。refunded 與 isPaid
  // 互相獨立、不互相覆蓋——isPaid 維持 true 保留「當初確實繳過費」的
  // 歷史紀錄，refunded=false 就是畫面上的「待退費」。經手人比照 paidBy。
  refunded   Boolean            @default(false)
  refundedAt DateTime?
  refundedBy String?
  status    RegistrationStatus @default(PENDING)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  checkIn   CheckIn?

  @@unique([eventId, email, name, phone])
  @@index([eventId])
}

model CheckIn {
  id             String       @id @default(cuid())
  registrationId String       @unique
  registration   Registration @relation(fields: [registrationId], references: [id])
  checkedAt      DateTime     @default(now())
  gate           String?
}

enum EventStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  WAITLISTED
}
